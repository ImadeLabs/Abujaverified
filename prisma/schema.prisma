datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

model Property {
  id          String   @id @default(cuid())
  title       String
  price       Float
  location    String
  description String   @db.Text
  videoUrl    String?
  images      String[]
  status      Status   @default(TIER_1_PENDING)
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  dueDiligenceRequests DueDiligence[] // links to DueDiligence
  media                PropertyMedia[] // links to PropertyMedia
}

model DueDiligence {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  notes     String?
  createdAt DateTime @default(now())

  status    String  @default("PENDING") // Add status field
  adminNote String? // Add adminNote field

  // Relation to Property
  property   Property? @relation(fields: [propertyId], references: [id])
  propertyId String?
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  phone     String
  type      String // "BUYER" or "LANDLORD"
  location  String?
  notes     String?
  status    String   @default("NEW") // NEW, CONTACTED, VERIFIED, CLOSED
  createdAt DateTime @default(now())
}

model PropertyMedia {
  id         Int      @id @default(autoincrement())
  propertyId String
  url        String
  createdAt  DateTime @default(now())

  // Relation to Property
  property Property @relation(fields: [propertyId], references: [id])
}

enum Status {
  TIER_1_PENDING
  VERIFIED
  SOLD
}
